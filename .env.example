# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_api_key_here

# Redis connection URL (leave default for local development)
# Format: redis://<host>:<port>
REDIS_URL=redis://localhost:6379

# Basic Auth credentials for dashboard access (P0)
# Change these in production!
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Docker: wait for Redis to be ready before starting app
# Set to "true" in docker-compose.yml
WAIT_FOR_REDIS=false